# --- Supabase ---
# From Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Resend (transactional email) ---
# From resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxx
NJ_NOTIFICATION_EMAIL=njock@booksbynj.com

# --- Cal.com booking ---
# Your Cal.com public link, e.g. https://cal.com/njock/discovery
NEXT_PUBLIC_CAL_LINK=njock/discovery

# --- Plausible analytics (optional) ---
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=booksbynj.com

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://booksbynj.com

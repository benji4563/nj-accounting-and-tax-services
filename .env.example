# --- Supabase ---
# From Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Resend (transactional email) ---
# From resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxx
NJ_NOTIFICATION_EMAIL=njock@booksbynj.com

# --- Cal.com booking ---
# Your Cal.com public link, e.g. https://cal.com/njock/discovery
NEXT_PUBLIC_CAL_LINK=njock/discovery

# --- Plausible analytics (optional) ---
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=booksbynj.com

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://booksbynj.com

# --- Search engine verification ---
# Google Search Console:
#   1. Go to https://search.google.com/search-console
#   2. Add property → URL prefix → https://booksbynj.com
#   3. Choose "HTML tag" verification method
#   4. Google gives you a string like: content="abc123xyz..."
#   5. Paste ONLY the value between the quotes here (not the full tag)
#   6. Redeploy — click "Verify" in Search Console
GOOGLE_SITE_VERIFICATION=

# Bing Webmaster Tools:
#   1. Go to https://www.bing.com/webmasters
#   2. Add site → HTML Meta Tag verification
#   3. Copy ONLY the msvalidate.01 content value here
BING_SITE_VERIFICATION=
